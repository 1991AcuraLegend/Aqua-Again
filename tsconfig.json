{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["DOM", "ES2020"]
  },
  "include": [
    "react/**/*.ts",
    "react/**/*.tsx",
    "examples/**/*.ts",
    "examples/**/*.tsx",
    "tsup.config.ts"
  ]
}